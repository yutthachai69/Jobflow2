# โหมดเทส — ข้อมูล clone จาก production แต่รันบน Docker ในเครื่อง (ไม่แตะ Supabase จริง)
#
# ครั้งแรก:
#   1) สร้าง .env.production.local มี DIRECT_URL=... (Supabase port 5432) สำหรับ sync เท่านั้น
#   2) npm run db:test:sync
#   3) npm run dev:test
#
# ทุกครั้งที่พัฒนา (หลัง sync แล้ว):
#   npm run dev:test
#
# สคริปต์ db:test:env จะสร้าง/อัปเดต .env.local ให้ชี้ localhost:5433 อัตโนมัติ
# แอปจะ error ถ้า DATABASE_URL ชี้ supabase.co ในโหมด dev (ยกเว้นตั้ง ALLOW_PRODUCTION_DATABASE=true)

DATABASE_URL="postgresql://postgres:postgres@localhost:5433/jobflow_test"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/jobflow_test"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# เก็บ credential production ไว้ใน .env.production.local เท่านั้น — อย่าใส่ใน .env.local
