# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# local DB dumps (scripts/db-dump-supabase.ps1)
/backups/

# database
*.db
*.db-journal
prisma/dev.db
prisma/*.db

# debug scripts
debug-*.js
fix-*.js

# local job photos (dev only)
public/job-photos/
.env*.local

# Docker image tar
*.tar

# DB backups / sensitive SQL dumps
*.sql.bak
jobflow2_backup.sql
restore-backup.js
extract-data.sh

# Scratch / one-off scripts
scratch_*.js
scratch_*.ts

# Raw data files (CSV/Excel planning docs)
DeleteData.csv
DeleteData.xlsx
*.csv
*.xlsx
