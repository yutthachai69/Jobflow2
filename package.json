{
  "name": "jobflow2",
  "version": "1.0.2",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:sqlite": "npm run use:sqlite && next dev --webpack",
    "use:sqlite": "npm run db:sqlite:generate",
    "use:postgres": "npm run db:generate",
    "dev:turbo": "next dev",
    "dev:network": "next dev -H 0.0.0.0",
    "dev:quiet": "node scripts/dev-quiet.js",
    "dev:silent": "node scripts/dev-silent.js",
    "build": "next build",
    "start": "next start",
    "start:prod": "npm run build && npm start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:add-adhoc-pm-type": "node scripts/add-jobitem-adhoc-pm-type.js",
    "db:generate": "prisma generate",
    "db:sqlite:push": "cross-env DATABASE_URL=file:./sqlite/dev.db prisma db push --schema=prisma/schema.sqlite.prisma --skip-generate",
    "db:sqlite:validate": "cross-env DATABASE_URL=file:./sqlite/dev.db prisma validate --schema=prisma/schema.sqlite.prisma",
    "db:sqlite:generate": "cross-env DATABASE_URL=file:./sqlite/dev.db prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:sqlite:studio": "cross-env DATABASE_URL=file:./sqlite/dev.db prisma studio --schema=prisma/schema.sqlite.prisma",
    "db:sqlite:seed": "cross-env DATABASE_URL=file:./sqlite/dev.db prisma db seed --schema=prisma/schema.sqlite.prisma",
    "db:studio": "prisma studio",
    "db:dump": "powershell -ExecutionPolicy Bypass -File scripts/db-dump-supabase.ps1",
    "db:push:prod": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5433/jobflow prisma db push",
    "db:push:both": "npm run db:push:prod && cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5433/jobflow_test prisma db push",
    "db:test:up": "docker compose up -d db",
    "db:test:sync": "powershell -ExecutionPolicy Bypass -File scripts/sync-prod-to-local-test.ps1 && npm run db:status:reconcile",
    "db:test:env": "node scripts/ensure-local-test-env.js",
    "db:test:verify": "node scripts/verify-local-test-db.js",
    "db:status:audit": "node scripts/work-order-status-audit.js",
    "db:status:reconcile": "node scripts/work-order-status-audit.js --fix",
    "dev:test": "npm run db:test:env && npm run use:postgres && next dev --webpack",
    "db:seed": "prisma db seed",
    "db:seed:run": "node scripts/run-seed.js",
    "db:migrate:resolve-user-locked": "node scripts/migrate-resolve-add-user-locked.js",
    "db:reset": "prisma migrate reset",
    "db:backup": "node scripts/backup-db.js",
    "db:migrate:postgres": "node scripts/migrate-data-to-postgresql.js",
    "db:check": "node scripts/verify-env-parity.js",
    "verify:parity": "node scripts/verify-env-parity.js",
    "assets:clear": "node scripts/clear-assets.js",
    "assets:generate": "node scripts/generate-assets.js",
    "docker:build": "docker build -t jobflow:latest .",
    "docker:save": "docker save -o jobflow-image.tar jobflow:latest",
    "docker:compose:build": "docker compose build web"
  },
  "dependencies": {
    "@line/bot-sdk": "^10.6.0",
    "@prisma/client": "^6.19.1",
    "@supabase/supabase-js": "^2.97.0",
    "@tailwindcss/postcss": "^4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/blob": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "html-to-image": "^1.11.13",
    "html2pdf.js": "^0.12.1",
    "html5-qrcode": "^2.3.8",
    "ioredis": "^5.9.1",
    "jose": "^6.1.3",
    "jspdf": "^4.2.0",
    "next": "^16.1.6",
    "puppeteer-core": "^25.1.0",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hot-toast": "^2.6.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "react-snowfall": "^2.4.0",
    "recharts": "^2.15.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/google.maps": "^3.58.1",
    "@types/jest": "^29.5.14",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20",
    "@types/react-signature-canvas": "^1.0.7",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prisma": "^6.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
